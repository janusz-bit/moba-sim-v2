PROJECT_NAME           = "moba-sim"
PROJECT_NUMBER         = 0.1.0
PROJECT_BRIEF          = "MOBA-style champion stat aggregation and combat simulation"

INPUT                  = ../include
RECURSIVE              = YES
FILE_PATTERNS          = *.hpp *.h
EXCLUDE_PATTERNS       = */build/*

OUTPUT_DIRECTORY       = .
GENERATE_HTML          = NO
GENERATE_XML           = YES
XML_OUTPUT             = xml
XML_PROGRAMLISTING     = NO

EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES

GENERATE_LATEX         = NO
GENERATE_MAN           = NO

QUIET                  = YES
WARN_IF_UNDOCUMENTED   = NO
WARN_NO_PARAMDOC       = NO

JAVADOC_AUTOBRIEF      = YES
QT_AUTOBRIEF           = NO
MULTILINE_CPP_IS_BRIEF = YES
INHERIT_DOCS           = YES
SEPARATE_MEMBER_PAGES  = NO

ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = NO
EXPAND_ONLY_PREDEF     = NO
SKIP_FUNCTION_MACROS   = YES

SORT_MEMBER_DOCS       = NO
SORT_BRIEF_DOCS        = NO
SORT_GROUP_DOCS        = NO
SORT_BY_SCOPE_NAME     = YES

BUILTIN_STL_SUPPORT    = YES
CPP_CLI_SUPPORT        = NO
SIP_SUPPORT            = NO
IDL_PROPERTY_SUPPORT   = NO